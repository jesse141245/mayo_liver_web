# Copy to .env.local for local overrides (do not commit .env or .env.local).
#
# Vite only exposes variables prefixed with VITE_ — they are embedded in the
# browser bundle. Use only public URLs here, never API keys or passwords.

# Production: set in Vercel → Project → Settings → Environment Variables
# Must match Flask routes: client calls `${BASE_URL}/health`, `/predict/...`, etc.
VITE_API_BASE_URL=https://your-api.example.com/api
